{
  "name": "@nakiros/desktop",
  "productName": "Nakiros",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-forge package",
    "make": "electron-vite build && electron-forge make --targets @electron-forge/maker-zip",
    "make:zip:arm64": "electron-vite build && electron-forge make --targets @electron-forge/maker-zip --arch=arm64",
    "make:zip:x64": "electron-vite build && electron-forge make --targets @electron-forge/maker-zip --arch=x64",
    "make:all": "electron-vite build && electron-forge make",
    "make:dmg": "electron-vite build && electron-forge make --targets @electron-forge/maker-dmg",
    "make:dmg:arm64": "electron-vite build && electron-forge make --targets @electron-forge/maker-dmg --arch=arm64",
    "make:dmg:x64": "electron-vite build && electron-forge make --targets @electron-forge/maker-dmg --arch=x64"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6",
    "lucide-react": "^0.575.0",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.7.0",
    "@electron-forge/maker-dmg": "^7.7.0",
    "@electron-forge/maker-zip": "^7.7.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.7.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "electron": "^34",
    "electron-vite": "^3",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5.9.0",
    "vite": "^6"
  }
}
