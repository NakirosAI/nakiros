    "open": "^11.0.0"
  },
  "devDependencies": {
    "@nakiros/agents-bundle": "workspace:*",
    "@nakiros/shared": "workspace:*",
    "@types/node": "^24.10.13",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
