{
  "name": "tiqora",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "desktop:package": "pnpm --filter @tiqora/desktop package",
    "desktop:make": "pnpm --filter @tiqora/desktop make",
    "desktop:make:all": "pnpm --filter @tiqora/desktop make:all",
    "desktop:make:dmg": "pnpm --filter @tiqora/desktop make:dmg",
    "desktop:make:dmg:arm64": "pnpm --filter @tiqora/desktop make:dmg:arm64",
    "desktop:make:dmg:x64": "pnpm --filter @tiqora/desktop make:dmg:x64",
    "desktop:make:zip:arm64": "pnpm --filter @tiqora/desktop make:zip:arm64",
    "desktop:make:zip:x64": "pnpm --filter @tiqora/desktop make:zip:x64"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "fs-xattr",
      "macos-alias",
      "node-pty"
    ]
  }
}
