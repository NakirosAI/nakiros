{
  "name": "@nakiros/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "nakiros": "./dist/bin/nakiros.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/nakiros.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.2.0",
    "@nakiros/shared": "workspace:*",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.5",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
