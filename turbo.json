{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@nakirosai/nakiros#build": {
      "dependsOn": ["^build", "@nakiros/frontend#build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["NAKIROS_*"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {}
  }
}
